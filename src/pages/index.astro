---
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection } from 'astro-pure/server'
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import Section from '@/components/home/Section.astro'
import { getFeaturedBlogPosts, normalizeBlogPost, sortBlogPosts } from '@/utils/blog'
import { site } from '@/site-config'

const allPosts = await getBlogCollection()
const normalizedPosts = allPosts.map(normalizeBlogPost)
const featuredPosts = getFeaturedBlogPosts(normalizedPosts)
const allPostsByDate = sortBlogPosts(normalizedPosts).slice(0, site.homePostLimit)
---

<PageLayout meta={{ title: '首頁' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section
      class='animate mb-12 flex max-w-3xl flex-col items-center gap-y-5 text-center'
      id='content-header'
    >
      <p class='text-sm font-medium uppercase tracking-[0.2em] text-muted-foreground'>
        story.dbb.tw
      </p>
      <h1 class='text-3xl font-medium sm:text-4xl'>用 AI 寫我想看的故事</h1>
      <div class='max-w-xl space-y-2 text-pretty leading-7 text-muted-foreground'>
        <p>我喜歡看故事，也喜歡一些不一定好找的題材。</p>
        <p>所以我用 AI 產生初稿，再依照自己的口味挑選、修改和整理。</p>
        <p>
          這裡的文章大多由 AI
          生成，並經過人工調整；它們不是現實經歷，也不是純人類創作，而是一批為了閱讀樂趣而做出的幻想故事。
        </p>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      {
        featuredPosts.length > 0 && (
          <Section title='精選文章'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {featuredPosts.map((p) => (
                <PostPreview post={p} />
              ))}
            </ul>
          </Section>
        )
      }

      {
        allPostsByDate.length > 0 && (
          <Section title='最新文章'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((p) => (
                <PostPreview post={p} />
              ))}
            </ul>
            <Button title='查看所有文章' class='w-fit self-end' href='/blog' variant='ahead' />
          </Section>
        )
      }
    </div>
  </main>
</PageLayout>
